# Firebase Cloud Functions 환경변수 템플릿
# 이 파일을 복사하여 .env.yaml 로 이름을 바꾸고 실제 키를 입력하세요.
# .env.yaml 은 .gitignore 에 포함되어 있으므로 절대 커밋하지 마세요.
#
# [프로덕션 배포 권장]
# firebase functions:secrets:set GEMINI_API_KEY
# firebase functions:secrets:set DATA_GO_KR_KEY
# 설정 후 main.py 의 @https_fn.on_request(secrets=[...]) 에 추가하세요.
GEMINI_API_KEY: "YOUR_GEMINI_API_KEY_HERE"
DATA_GO_KR_KEY: "YOUR_DATA_GO_KR_KEY_HERE"

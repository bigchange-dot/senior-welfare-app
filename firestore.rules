rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // welfare_notices: 앱(인증된 사용자)은 읽기만 가능, 쓰기는 서버(Admin SDK)만 허용
    match /welfare_notices/{docId} {
      allow read: if true;          // 앱에서 목록 조회 허용 (익명 포함)
      allow write: if false;        // 클라이언트 직접 쓰기 차단 (Admin SDK만 쓰기)
    }

    // 기타 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
